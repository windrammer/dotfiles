#!/bin/bash
# 🏗️ git pushbuild — push the current branch and trigger a Woodpecker CI build
#
# Usage: git pushbuild
#
# Only triggers for repos under github.com/Toll-net.
# Token is stored in macOS Keychain under service "woodpecker-api-token".
#
# First-time setup:
#   security add-generic-password -s woodpecker-api-token -a token -w "<YOUR_TOKEN>"

set -e

WOODPECKER_URL="https://woodpecker.home.arpa"
ALLOWED_ORG="Toll-net"

# Must be inside a git repo
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "❌ Not inside a git repository"
  exit 1
fi

# Derive org/repo from the remote URL
REMOTE_URL=$(git remote get-url origin 2>/dev/null)
REPO=$(echo "$REMOTE_URL" | sed -E 's#\.git$##; s#.*[:/]([^/]+/[^/]+)$#\1#')

if [ -z "$REPO" ]; then
  echo "❌ Could not determine repo from remote URL"
  exit 1
fi

# Only allow repos under the homelab org
ORG=$(echo "$REPO" | cut -d/ -f1)
if [ "$ORG" != "$ALLOWED_ORG" ]; then
  echo "❌ Repo belongs to '$ORG', not '$ALLOWED_ORG' — skipping build trigger"
  echo "   Use plain 'git push' instead"
  exit 1
fi

# Read token from macOS Keychain
TOKEN=$(security find-generic-password -s woodpecker-api-token -a token -w 2>/dev/null || true)

if [ -z "$TOKEN" ]; then
  echo "❌ No Woodpecker token in Keychain (service: woodpecker-api-token)"
  echo "   Run: security add-generic-password -s woodpecker-api-token -a token -w \"<TOKEN>\""
  exit 1
fi

# Branch to trigger is the one we're pushing
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)
if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
  echo "❌ Could not determine current branch"
  exit 1
fi

# Push first
git push "$@"

# Woodpecker 3.x uses numeric repo IDs; look ours up from owner/name
LOOKUP=$(curl -s -w "\n%{http_code}" \
  -H "Authorization: Bearer $TOKEN" \
  "$WOODPECKER_URL/api/repos/lookup/$REPO" 2>/dev/null || true)
LOOKUP_CODE=$(echo "$LOOKUP" | tail -1)
LOOKUP_BODY=$(echo "$LOOKUP" | sed '$d')

if [ "$LOOKUP_CODE" != "200" ]; then
  echo "⚠️  Could not look up '$REPO' on Woodpecker (HTTP $LOOKUP_CODE) — is it activated?"
  echo "   Push succeeded, but no build was triggered"
  exit 0
fi

REPO_ID=$(echo "$LOOKUP_BODY" | jq -r '.id // empty')
if [ -z "$REPO_ID" ]; then
  echo "⚠️  Could not parse repo ID from Woodpecker lookup response"
  echo "   Push succeeded, but no build was triggered"
  exit 0
fi

# Trigger the build
RESPONSE=$(curl -s -w "\n%{http_code}" \
  -X POST "$WOODPECKER_URL/api/repos/$REPO_ID/pipelines" \
  -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/json" \
  -d "{\"branch\": \"$BRANCH\"}" 2>/dev/null || true)

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

case "$HTTP_CODE" in
  200|201)
    NUMBER=$(echo "$BODY" | jq -r '.number // empty')
    if [ -n "$NUMBER" ]; then
      echo "🏗️ Woodpecker build #$NUMBER triggered for $REPO ($BRANCH)"
      echo "   $WOODPECKER_URL/repos/$REPO_ID/pipeline/$NUMBER"
    else
      echo "⚠️  Unexpected response from Woodpecker (HTTP 200 but no pipeline number)"
      [ -n "$BODY" ] && echo "   $(echo "$BODY" | head -c 200)"
    fi
    ;;
  *)
    echo "⚠️  Woodpecker trigger returned HTTP $HTTP_CODE for $REPO ($BRANCH)"
    [ -n "$BODY" ] && echo "   $(echo "$BODY" | head -c 200)"
    echo "   Push succeeded, but no build was triggered"
    ;;
esac
