[user]
	name = David Tollman

[include]
	path = ~/git/dotfiles/mac/gitconfig-work

[includeIf "gitdir:~/git/privat/"]
	path = ~/git/dotfiles/mac/gitconfig-private

[includeIf "gitdir:~/git/dotfiles/"]
	path = ~/git/dotfiles/mac/gitconfig-private

[commit]
	gpgsign = true
	template = ~/.git-commit-template

[tag]
	gpgsign = true

[pull]
	rebase = true

[core]
	excludesfile = ~/.gitignore_global
	hooksPath = ~/.git-hooks

[init]
	defaultBranch = main
[url "git@github.com:playgroundtech/"]
	insteadOf = https://github.com/playgroundtech/

# Canonicalize claude-settings.json: sort keys and drop effortLevel (which
# /effort rewrites at runtime), so Claude Code's runtime changes don't show
# as diffs (see mac/.gitattributes).
[filter "claude-settings"]
	clean = jq -S 'del(.effortLevel)'
